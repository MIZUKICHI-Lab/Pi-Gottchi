# もこ のAPIキー設定（.env にコピーして記入。コミット禁止）
GEMINI_API_KEY=ここにGeminiのAPIキー
# 省略可: モデル上書き
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# 省略可: Live音声調整（通常は既定値のままで使う）
# LIVE_CHUNK_MS=100
# LIVE_SILENCE_MS=700
# LIVE_ECHO_GUARD_MS=350
# 声紋ライト実験 (log=返答後に一致度をログ / gate=応答前に判定 / off=既定)
# VOICEPRINT=off

# 画面の明るさ（0〜100）
# AWAKE_BACKLIGHT=100
# Pi Zero WのON/OFFバックライトでは1〜100は点灯、消す場合だけ0
# SLEEP_BACKLIGHT=12
# 起動直後はWi-Fi・時刻同期を待つため自動睡眠しない
# STARTUP_AWAKE_SEC=240
# AUTO_SLEEP_SEC=300
# NIGHT_AUTO_SLEEP_SEC=120

# サーボは配線・外部電源・無負荷校正が済んだ場合だけ有効にする
# SERVO_ENABLED=0
# SERVO_CHANNEL=0
# SERVO_MIN_ANGLE=70
# SERVO_CENTER=90
# SERVO_MAX_ANGLE=110
# SERVO_SLEEP_ANGLE=80
# SERVO_MIN_PULSE_US=500
# SERVO_MAX_PULSE_US=2400
# SERVO_REVERSED=0
# SERVO_HOLD=0
