[Unit]
Description=Moko tamagotchi character
# 注意: whisplay-soundcard-warmup は After=multi-user.target を持つため
# After に入れると順序循環になり moko の起動が systemd に削除される（実績あり）
After=sound.target

[Service]
WorkingDirectory=/home/mizukichi/Pi-Gottchi/app
ExecStart=/usr/bin/python3 -u /home/mizukichi/Pi-Gottchi/app/chara.py
Restart=always
RestartSec=3
# Pi Zeroの単一CPUが混雑しても音声sender/receiverを優先する。
Nice=-5
CPUWeight=900
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
